# Copy this file to .env before running docker-compose
# cp .env.example .env

# Your local user ID — used to set correct file permissions inside the container
# Run: echo "AIRFLOW_UID=$(id -u)" to get your value (Linux/Mac)
# On Windows with WSL, use: AIRFLOW_UID=50000
AIRFLOW_UID=50000

# Generate a Fernet key for encrypting sensitive data in Airflow
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
